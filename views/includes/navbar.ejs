<style>
  .search-btn{
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0 1rem;
  }

  .search-btn:hover{
    background-color: #fe424d;
    color: white;
  }

  .search-btn i{
    margin-right: 0.5rem;
  }

  .search-input{
    border-radius: 25px;
    border: 1px solid #ced4da;
    padding: 0.5rem 3rem;
    font-size: 0.9rem;
    width: 250px;
    transition: width 0.3s ease-in-out;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- Brand -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-hotel"></i>
    </a>

    <!-- Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar content -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- Middle Search -->
      <form class="d-flex mx-auto" role="search" method="GET" action="/listings/search">
        <input 
          class="form-control me-2 search-input"
          type="search"
          name="q"
          placeholder="Search Destination">

        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
          Search
        </button>
      </form>

      <!-- Right -->
      <div class="navbar-nav ms-auto align-items-center">

        <a class="nav-link" href="/listings/new">Airbnb your place</a>

        <% if(!currentUser){ %>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>

        <% if(currentUser){ %>

<div class="dropdown ms-3">

  <button class="btn profile-btn dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown">

      <i class="fa-solid fa-user"></i>

      <%= currentUser.username.charAt(0).toUpperCase() %>

  </button>

  <ul class="dropdown-menu dropdown-menu-end">

    <li>
      <a class="dropdown-item" href="/listings/mylistings">
        My Listings
      </a>
    </li>

    <li>
      <a class="dropdown-item" href="/wishlist">
        Wishlist ❤️
      </a>
    </li>

    <li>
      <a class="dropdown-item" href="/profile">
        Profile
      </a>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
      <a class="dropdown-item text-danger" href="/logout">
        Logout
      </a>
    </li>

  </ul>

</div>

<% } %>

        <!-- Theme Button -->
        <button id="themeToggle" class="btn btn-dark ms-2">
          🌙
        </button>

      </div>

    </div>
  </div>
</nav>
<% layout("/layouts/boilerplate") %>

<h2 class="mt-3 mb-4">My Listings</h2>

<div class="row">

<% for(let listing of listings){ %>

<a href="/listings/<%= listing._id %>" class="listing-link col-md-4">

<div class="card listing-card">

<img
src="<%= listing.images[0].url %>"
class="card-img-top">

<div class="card-body">

<h5 class="card-title">
<%= listing.title %>
</h5>

<p class="card-text price">
₹ <%= listing.price.toLocaleString("en-IN") %>
</p>

<p class="card-text">
<%= listing.location %>, <%= listing.country %>
</p>

</div>

</div>

</a>

<% } %>

</div>